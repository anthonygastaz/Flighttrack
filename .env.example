# =============================================================================
# Evaair FlightTrack — Environment Variables
# Copy to `.env.local` and fill in the values. Never commit `.env.local`.
# =============================================================================

# --- Supabase (required) -----------------------------------------------------
# Project URL and anon key from: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key — server-only. Used by the admin repository to bypass RLS
# for trusted server actions. NEVER expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- App ---------------------------------------------------------------------
# Public base URL of the deployment (used for absolute links / emails).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated list of email addresses that are granted admin access.
# A signed-in Supabase user whose email is in this list passes the admin gate.
ADMIN_EMAILS=admin@yourdomain.com

# --- Amadeus Flight API (optional) -------------------------------------------
# Live flight status enrichment. If unset, flight lookups degrade gracefully.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_BASE_URL=https://test.api.amadeus.com

# --- Resend email (optional) -------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=Evaair FlightTrack <noreply@yourdomain.com>

# --- Twilio SMS (optional) ---------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
